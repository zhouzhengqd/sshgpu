{
  "name": "sshgpu",
  "version": "0.1.0",
  "description": "macOS menu bar app for monitoring remote GPU servers via SSH",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --outdir=dist/main --external:electron --external:ssh2 --external:electron-store --format=cjs --sourcemap --watch",
    "dev:electron": "wait-on http://localhost:5173 && NODE_ENV=development VITE_DEV_PORT=5173 electron .",
    "build": "npm run build:main && vite build",
    "build:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --outdir=dist/main --external:electron --external:ssh2 --external:electron-store --format=cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.1.0",
    "wait-on": "^9.0.5"
  }
}
